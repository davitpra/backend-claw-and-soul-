generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 2.1 Users
model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  fullName          String?   @map("full_name")
  role              String    @default("user") // Enum: user, premium, admin
  shopifyCustomerId String?   @unique @map("shopify_customer_id")
  emailVerified     Boolean   @default(false) @map("email_verified")
  isActive          Boolean   @default(true) @map("is_active")
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  // Relations
  credits            UserCredits?
  creditTransactions CreditTransaction[]
  pets               Pet[]
  generations        Generation[]
  shopifyOrders      ShopifyOrder[]
  auditLogs          AuditLog[]
  refreshTokens      RefreshToken[]

  @@index([email])
  @@index([shopifyCustomerId])
  @@index([role])
  @@map("users")
}

// 2.2 UserCredits
model UserCredits {
  id          String   @id @default(uuid())
  userId      String   @unique @map("user_id")
  balance     Int      @default(0)
  totalEarned Int      @default(0) @map("total_earned")
  totalSpent  Int      @default(0) @map("total_spent")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_credits")
}

// 2.3 CreditTransactions
model CreditTransaction {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  type          String // Enum: earned, spent, refund, bonus
  amount        Int
  balanceAfter  Int      @map("balance_after")
  description   String?
  referenceType String?  @map("reference_type")
  referenceId   String?  @map("reference_id")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("credit_transactions")
}

// 2.4 Pets
model Pet {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  species     String // Enum: dog, cat, bird, rabbit, other
  breed       String?
  age         Int?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos      PetPhoto[]
  generations Generation[]

  @@index([userId])
  @@index([species])
  @@index([userId, isActive])
  @@map("pets")
}

// 2.5 PetPhotos
model PetPhoto {
  id              String   @id @default(uuid())
  petId           String   @map("pet_id")
  photoUrl        String   @map("photo_url")
  photoStorageKey String   @map("photo_storage_key")
  isPrimary       Boolean  @default(false) @map("is_primary")
  orderIndex      Int      @default(0) @map("order_index")
  createdAt       DateTime @default(now()) @map("created_at")

  pet         Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  generations Generation[]

  @@index([petId])
  @@index([petId, isPrimary])
  @@index([petId, orderIndex])
  @@map("pet_photos")
}

// 2.6 Styles
model Style {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  category    String
  previewUrl  String?  @map("preview_url")
  costCredits Int      @default(1) @map("cost_credits")
  isActive    Boolean  @default(true) @map("is_active")
  isPremium   Boolean  @default(false) @map("is_premium")
  parameters  Json?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  generations Generation[]

  @@index([category])
  @@index([isActive])
  @@index([sortOrder])
  @@index([category, isActive])
  @@map("styles")
}

// 2.7 Generations
model Generation {
  id                    String    @id @default(uuid())
  userId                String    @map("user_id")
  petId                 String    @map("pet_id")
  petPhotoId            String?   @map("pet_photo_id")
  styleId               String    @map("style_id")
  type                  String // Enum: image, video
  status                String    @default("pending") // Enum: pending, processing, completed, failed
  prompt                String
  negativePrompt        String?   @map("negative_prompt")
  resultUrl             String?   @map("result_url")
  resultStorageKey      String?   @map("result_storage_key")
  thumbnailUrl          String?   @map("thumbnail_url")
  provider              String
  costCredits           Int       @map("cost_credits")
  processingTimeSeconds Int?      @map("processing_time_seconds")
  errorMessage          String?   @map("error_message")
  metadata              Json?
  isPublic              Boolean   @default(false) @map("is_public")
  isFavorite            Boolean   @default(false) @map("is_favorite")
  createdAt             DateTime  @default(now()) @map("created_at")
  completedAt           DateTime? @map("completed_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pet      Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)
  petPhoto PetPhoto? @relation(fields: [petPhotoId], references: [id], onDelete: SetNull)
  style    Style     @relation(fields: [styleId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([petId])
  @@index([petPhotoId])
  @@index([status])
  @@index([type])
  @@index([userId, status])
  @@index([userId, type])
  @@index([createdAt(sort: Desc)])
  @@map("generations")
}

// 2.8 ShopifyOrders
model ShopifyOrder {
  id                String    @id @default(uuid())
  userId            String?   @map("user_id")
  shopifyOrderId    String    @unique @map("shopify_order_id")
  orderNumber       String    @map("order_number")
  email             String
  totalPrice        Decimal   @map("total_price")
  currency          String    @default("USD")
  financialStatus   String?   @map("financial_status")
  fulfillmentStatus String?   @map("fulfillment_status")
  lineItems         Json      @map("line_items")
  customerInfo      Json?     @map("customer_info")
  creditsAwarded    Int       @default(0) @map("credits_awarded")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")
  shopifyCreatedAt  DateTime? @map("shopify_created_at")
  shopifyUpdatedAt  DateTime? @map("shopify_updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([shopifyOrderId])
  @@index([email])
  @@index([createdAt(sort: Desc)])
  @@map("shopify_orders")
}

// 2.9 ShopifyProducts
model ShopifyProduct {
  id               String    @id @default(uuid())
  shopifyProductId String    @unique @map("shopify_product_id")
  title            String
  description      String?
  vendor           String?
  productType      String?   @map("product_type")
  price            Decimal?
  compareAtPrice   Decimal?  @map("compare_at_price")
  images           Json?
  variants         Json?
  tags             String[] // PostgreSQL supports arrays natively
  isActive         Boolean   @default(true) @map("is_active")
  creditsReward    Int       @default(0) @map("credits_reward")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")
  shopifyCreatedAt DateTime? @map("shopify_created_at")
  shopifyUpdatedAt DateTime? @map("shopify_updated_at")

  @@index([shopifyProductId])
  @@index([isActive])
  @@map("shopify_products")
}

// 2.10 AuditLogs
model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// 2.11 RefreshTokens
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}
