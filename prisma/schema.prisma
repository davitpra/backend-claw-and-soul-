generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTHENTICATION & USERS
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  fullName      String?   @map("full_name")
  role          String    @default("user") // Enum: user, premium, admin
  emailVerified Boolean   @default(false) @map("email_verified")
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")

  // Relations
  pets          Pet[]
  generations   Generation[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  isRevoked Boolean  @default(false) @map("is_revoked")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ============================================
// PETS & PET PHOTOS
// ============================================

model Pet {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  species     String // Enum: dog, cat, bird, rabbit, other
  breed       String?
  age         Int?
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  photos      PetPhoto[]
  generations Generation[]

  @@index([userId])
  @@index([species])
  @@index([userId, isActive])
  @@map("pets")
}

model PetPhoto {
  id              String   @id @default(uuid())
  petId           String   @map("pet_id")
  photoUrl        String   @map("photo_url")
  photoStorageKey String   @map("photo_storage_key")
  isPrimary       Boolean  @default(false) @map("is_primary")
  orderIndex      Int      @default(0) @map("order_index")
  createdAt       DateTime @default(now()) @map("created_at")

  pet         Pet          @relation(fields: [petId], references: [id], onDelete: Cascade)
  generations Generation[]

  @@index([petId])
  @@index([petId, isPrimary])
  @@index([petId, orderIndex])
  @@map("pet_photos")
}

// ============================================
// STYLES & STYLE IMAGES
// ============================================

model Style {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String   @map("display_name")
  description String?
  category    String
  previewUrl  String?  @map("preview_url")
  isActive    Boolean  @default(true) @map("is_active")
  isPremium   Boolean  @default(false) @map("is_premium")
  parameters  Json?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  generations  Generation[]
  images       StyleImage[]
  compatMatrix StyleFormatProductCompat[]

  @@index([category])
  @@index([isActive])
  @@index([sortOrder])
  @@index([category, isActive])
  @@map("styles")
}

model StyleImage {
  id         String   @id @default(uuid())
  styleId    String   @map("style_id")
  imageUrl   String   @map("image_url")
  storageKey String   @map("storage_key")
  caption    String?
  orderIndex Int      @map("order_index")
  isPrimary  Boolean  @default(false) @map("is_primary")
  createdAt  DateTime @default(now()) @map("created_at")

  style Style @relation(fields: [styleId], references: [id], onDelete: Cascade)

  @@index([styleId])
  @@index([styleId, orderIndex])
  @@map("style_images")
}

// ============================================
// FORMATS & PRODUCT REFERENCES
// ============================================

model Format {
  id          String   @id @default(uuid())
  name        String   @unique
  displayName String   @map("display_name")
  aspectRatio String   @map("aspect_ratio")
  width       Int
  height      Int
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  generations  Generation[]
  compatMatrix StyleFormatProductCompat[]

  @@index([isActive])
  @@map("formats")
}

model ProductReference {
  id               String   @id @default(uuid())
  shopifyProductId String   @unique @map("shopify_product_id")
  name             String
  displayName      String   @map("display_name")
  description      String?
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  generations  Generation[]
  compatMatrix StyleFormatProductCompat[]

  @@index([isActive])
  @@map("product_references")
}

// ============================================
// COMPATIBILITY MATRIX
// ============================================

model StyleFormatProductCompat {
  id           String   @id @default(uuid())
  styleId      String   @map("style_id")
  formatId     String   @map("format_id")
  productRefId String   @map("product_ref_id")
  constraints  Json?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  style      Style            @relation(fields: [styleId], references: [id], onDelete: Cascade)
  format     Format           @relation(fields: [formatId], references: [id], onDelete: Cascade)
  productRef ProductReference @relation(fields: [productRefId], references: [id], onDelete: Cascade)

  @@unique([styleId, formatId, productRefId])
  @@index([styleId])
  @@index([formatId])
  @@map("style_format_product_compat")
}

// ============================================
// GENERATIONS
// ============================================

model Generation {
  id                    String    @id @default(uuid())
  userId                String    @map("user_id")
  petId                 String    @map("pet_id")
  petPhotoId            String?   @map("pet_photo_id")
  styleId               String    @map("style_id")
  formatId              String?   @map("format_id")
  productRefId          String?   @map("product_ref_id")
  type                  String // Enum: image, video
  status                String    @default("pending") // Enum: pending, processing, completed, failed
  prompt                String
  negativePrompt        String?   @map("negative_prompt")
  resultUrl             String?   @map("result_url")
  resultStorageKey      String?   @map("result_storage_key")
  thumbnailUrl          String?   @map("thumbnail_url")
  provider              String
  processingTimeSeconds Int?      @map("processing_time_seconds")
  errorMessage          String?   @map("error_message")
  metadata              Json?
  isPublic              Boolean   @default(false) @map("is_public")
  isFavorite            Boolean   @default(false) @map("is_favorite")
  createdAt             DateTime  @default(now()) @map("created_at")
  completedAt           DateTime? @map("completed_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pet        Pet               @relation(fields: [petId], references: [id], onDelete: Cascade)
  petPhoto   PetPhoto?         @relation(fields: [petPhotoId], references: [id], onDelete: SetNull)
  style      Style             @relation(fields: [styleId], references: [id], onDelete: Restrict)
  format     Format?           @relation(fields: [formatId], references: [id], onDelete: SetNull)
  productRef ProductReference? @relation(fields: [productRefId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([petId])
  @@index([petPhotoId])
  @@index([status])
  @@index([type])
  @@index([userId, status])
  @@index([userId, type])
  @@index([createdAt(sort: Desc)])
  @@map("generations")
}

// ============================================
// AUDIT LOGS
// ============================================

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// ============================================
// SYNC LOGS
// ============================================

model SyncLog {
  id                  String    @id @default(uuid())
  type                String    // 'cron' | 'manual' | 'webhook'
  status              String    // 'running' | 'completed' | 'failed'
  startedAt           DateTime  @map("started_at")
  completedAt         DateTime? @map("completed_at")
  productsChecked     Int?      @map("products_checked")
  productsCreated     Int?      @map("products_created")
  productsUpdated     Int?      @map("products_updated")
  productsDeactivated Int?      @map("products_deactivated")
  errors              Json?
  metadata            Json?
  createdAt           DateTime  @default(now()) @map("created_at")

  @@index([type])
  @@index([status])
  @@index([startedAt(sort: Desc)])
  @@map("sync_logs")
}
